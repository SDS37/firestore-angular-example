{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "firebase-example-app",
      "public": "dist/firebase-example-app/browser",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".git",
        ".gitignore",
        ".editorconfig",
        "firestore.rules",
        "firestore.indexes.json",
        "database.rules.json",
        "package.json",
        "README.md",
        "tsconfig.json",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
